{
  "name": "simplo-coffee-js",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:reset": "docker compose down -v && docker compose up -d --wait && prisma db push && prisma db seed",
    "check": "biome check .",
    "check:apply": "biome check --write .",
    "format": "biome format --write .",
    "tunnel": "bash scripts/tunnel.sh",
    "dev:tunnel": "WITH_DEV=1 bash scripts/tunnel.sh"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "lefthook"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@libsql/client": "^0.17.0",
    "@mgcrea/prisma-queue": "^2.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.4.2",
    "better-auth": "^1.5.4",
    "currency.js": "^2.0.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.1",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "lefthook": "^2.1.4",
    "msw": "^2.12.10",
    "prisma": "^7.4.2",
    "testcontainers": "^11.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
